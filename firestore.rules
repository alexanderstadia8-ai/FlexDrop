rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Donations - anyone can read, only server (admin SDK) can write
    match /donations/{id} {
      allow read: if true;
      allow write: if false;
    }

    // All-time leaderboard - anyone can read, only server can write
    match /leaderboard_alltime/{uid} {
      allow read: if true;
      allow write: if false;
    }

    // Pending donations - only the authenticated user can read/write their own
    match /pending_donations/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
